# =========================================================================
# FOODSHARE AI - GLOBAL ENVIRONMENT CONFIGURATION
# =========================================================================

# --- SUPABASE CONFIGURATION (Required for Backend) ---
# Get these from your Supabase Project Settings > API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# --- BACKEND AUTH & SECURITY ---
JWT_SECRET=generate-a-secure-random-string
PORT=8214

# --- AI SERVICE CONFIGURATION ---
# If running locally: http://localhost:8000
# If deployed on Render: https://your-ai-service.onrender.com
AI_SERVICE_URL=http://localhost:8000

# --- FRONTEND CONFIGURATION ---
# Usually just /api if backend serves frontend, or http://localhost:8214/api for local dev
VITE_API_URL=/api
